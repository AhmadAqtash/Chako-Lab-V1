# ─── Shopify Storefront API ────────────────────────────────────────────────────
# Both variables are required. The storefront token is a PUBLIC read-only key
# (safe to expose client-side if needed, but this project only uses it server-side).
#
# Where to get them:
#   Shopify Admin → Settings → Apps and sales channels
#   → Develop apps → Create an app → Storefront API credentials

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
